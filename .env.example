# Inbox for contact form submissions (required in production)
CONTACT_TO_EMAIL=you@example.com

# Gmail: App Password (Google Account → Security → 2-Step Verification → App passwords)
SMTP_USER=your-account@gmail.com
# Paste the 16-character app password as one string (spaces are OK; they are stripped)
SMTP_PASS=your-app-password

# SMTP host (optional for Gmail):
# — Leave SMTP_HOST unset to use Nodemailer’s built-in Gmail transport (recommended for App Passwords).
# — For other providers, set your SMTP hostname here.
# — For Gmail with explicit port 587 + STARTTLS, set SMTP_GMAIL_EXPLICIT=true and set SMTP_HOST in your private .env (not committed).
SMTP_PORT=587
SMTP_SECURE=false
# SMTP_HOST=

# Set to "true" only if you need explicit host/port instead of the Gmail preset (e.g. port 587 + STARTTLS).
# SMTP_GMAIL_EXPLICIT=true

# Optional "From" header (defaults to SMTP_USER)
# SMTP_FROM="Сайт контакт <your-account@gmail.com>"

# --- Production note ---
# `node dist/index.js` loads `.env` from the project folder (parent of `dist/`), not from the shell cwd.
# Copy this file to `.env` next to `package.json` on the server.

# --- Optional: Umami analytics (Vite injects at build time) ---
# Set before `pnpm build` if you use Umami; leave unset to omit the script from index.html.
# VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
# VITE_ANALYTICS_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
