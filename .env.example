# Inbox for form notifications
CONTACT_TO_EMAIL=you@example.com

# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Verified sender in Resend (https://resend.com/domains). Visitor email is only used as Reply-To.
RESEND_FROM="Studio <notifications@your-verified-domain.com>"

# --- Production: Resend runs on your API host (Node, serverless, etc.) ---
# Set RESEND_API_KEY, RESEND_FROM, CONTACT_TO_EMAIL there—not in the static site bundle.

# --- GitHub Pages + Actions: contact POST URL (required for production build) ---
# In GitHub: Settings → Secrets and variables → Actions — add Secret OR Variable:
#   Name:  VITE_CONTACT_API_URL   (must start with VITE_ or Vite will not embed it)
#   Value: https://your-api-host.example.com/api/contact
# Optional locally in .env for testing production-like builds:
# VITE_CONTACT_API_URL=https://...

# --- Optional: Umami (set before `pnpm build`) ---
# VITE_ANALYTICS_ENDPOINT=https://...
# VITE_ANALYTICS_WEBSITE_ID=...
