# Inbox for form notifications
CONTACT_TO_EMAIL=you@example.com

# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Verified sender in Resend (https://resend.com/domains). Visitor email is only used as Reply-To.
RESEND_FROM="Studio <notifications@your-verified-domain.com>"

# --- Production / Netlify ---
# Set RESEND_API_KEY, RESEND_FROM, CONTACT_TO_EMAIL.

# --- Optional: Umami (set before `pnpm build`) ---
# VITE_ANALYTICS_ENDPOINT=https://...
# VITE_ANALYTICS_WEBSITE_ID=...
